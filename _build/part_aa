<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Zenith — Minimal Navigation</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ========== RESET & BASE ========== */
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

:root {
  --surface: #fafafa;
  --surface-secondary: #f5f5f5;
  --surface-hover: #eeeeee;
  --text-primary: #111111;
  --text-secondary: #666666;
  --text-tertiary: #999999;
  --accent: #888888;
  --accent-hover: #aaaaaa;
  --border: #e8e8e8;
}

.dark {
  --surface: #1a1a1a;
  --surface-secondary: #222222;
  --surface-hover: #2a2a2a;
  --text-primary: #e8e8e8;
  --text-secondary: #999999;
  --text-tertiary: #666666;
  --accent: #888888;
  --accent-hover: #aaaaaa;
  --border: #2a2a2a;
}

html {
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
}

body {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  background-color: var(--surface);
  color: var(--text-primary);
  transition: background-color 0.5s ease, color 0.5s ease;
  min-height: 100vh;
  overflow-x: hidden;
}

::selection { background-color: var(--accent); color: var(--surface); }

::-webkit-scrollbar { width: 3px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: color-mix(in srgb, var(--text-tertiary) 40%, transparent); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-secondary); }

*:focus-visible { outline: 1px solid var(--accent); outline-offset: 2px; border-radius: 2px; }
input::placeholder { color: var(--text-tertiary); }

a { color: inherit; text-decoration: none; }
button { font-family: inherit; cursor: pointer; border: none; background: none; color: inherit; }

/* ========== LAYOUT ========== */
.app { min-height: 100vh; display: flex; flex-direction: column; }

/* ========== TOP BAR ========== */
.top-bar {
  width: 100%; padding: 20px 32px;
  display: flex; align-items: center; justify-content: space-between;
  opacity: 0; animation: fadeIn 0.8s cubic-bezier(0.16,1,0.3,1) forwards;
}
.logo-area { display: flex; align-items: center; gap: 10px; min-width: 0; flex-shrink: 0; }
.logo-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--text-tertiary);
  transition: background 0.3s ease;
}
.logo-name { font-size: 13px; font-weight: 400; letter-spacing: 0.06em; color: var(--text-tertiary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

.search-area { position: relative; flex: 1; max-width: 400px; margin: 0 32px; }
.search-icon { position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: 14px; height: 14px; color: var(--text-tertiary); pointer-events: none; opacity: 0.6; transition: opacity 0.3s ease; }
.search-input {
  width: 100%; background: transparent; font-size: 13px; font-weight: 400; color: var(--text-primary);
  padding: 8px 56px 8px 22px; outline: none;
  border: none; border-bottom: 1px solid transparent;
  transition: border-color 0.4s cubic-bezier(0.16,1,0.3,1);
}
.search-input:focus { border-bottom-color: var(--text-secondary); }
.search-input:focus ~ .search-icon { opacity: 1; }
.search-input:not(:focus):hover { border-bottom-color: color-mix(in srgb, var(--text-tertiary) 25%, transparent); }
.search-kbd { position: absolute; right: 0; top: 50%; transform: translateY(-50%); display: flex; gap: 2px; pointer-events: none; }
.search-kbd kbd { font-size: 10px; color: color-mix(in srgb, var(--text-tertiary) 40%, transparent); font-family: 'SF Mono', ui-monospace, monospace; }

.top-actions { display: flex; align-items: center; gap: 2px; flex-shrink: 0; }
.icon-btn {
  width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;
  border-radius: 8px; color: var(--text-tertiary); transition: all 0.25s cubic-bezier(0.16,1,0.3,1);
}
.icon-btn:hover { color: var(--text-primary); background: var(--surface-hover); }
.icon-btn svg { width: 16px; height: 16px; stroke-width: 1.5; }

/* ========== SEARCH RESULTS ========== */
.search-results {
  position: absolute; top: 100%; left: 0; right: 0; margin-top: 8px; z-index: 50;
  background: color-mix(in srgb, var(--surface) 85%, transparent);
  backdrop-filter: blur(20px) saturate(1.2);
  -webkit-backdrop-filter: blur(20px) saturate(1.2);
  border: 1px solid color-mix(in srgb, var(--border) 50%, transparent);
  border-radius: 10px; overflow: hidden;
  opacity: 0; transform: translateY(-4px); pointer-events: none;
  transition: opacity 0.2s cubic-bezier(0.16,1,0.3,1), transform 0.2s cubic-bezier(0.16,1,0.3,1);
  box-shadow: 0 8px 32px color-mix(in srgb, var(--surface) 80%, black);
}
.search-results.active { opacity: 1; transform: translateY(0); pointer-events: auto; }
.search-group-label { padding: 8px 14px 4px; font-size: 10px; text-transform: uppercase; letter-spacing: 0.1em; color: color-mix(in srgb, var(--text-tertiary) 60%, transparent); font-weight: 500; }
.search-result-item {
  width: 100%; display: flex; align-items: center; gap: 10px;
  padding: 7px 14px; text-align: left; transition: background-color 0.15s ease; border-radius: 6px; margin: 0 4px;
}
.search-result-item:hover, .search-result-item.selected { background: var(--surface-hover); }
.search-result-item .title { font-size: 13px; color: var(--text-primary); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.search-result-item .url { font-size: 11px; color: color-mix(in srgb, var(--text-tertiary) 40%, transparent); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 160px; }

/* ========== SEARCH DIALOG (Cmd+K) ========== */
.search-overlay {
  position: fixed; inset: 0; z-index: 100;
  background: rgba(0,0,0,0.25); backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  opacity: 0; pointer-events: none; transition: opacity 0.2s ease;
}
.search-overlay.active { opacity: 1; pointer-events: auto; }
.search-dialog {
  position: fixed; left: 50%; top: 20%; z-index: 101;
  width: 90%; max-width: 520px; transform: translateX(-50%) translateY(-8px) scale(0.98);
  background: color-mix(in srgb, var(--surface) 90%, transparent);
  backdrop-filter: blur(24px) saturate(1.3);
  -webkit-backdrop-filter: blur(24px) saturate(1.3);
  border: 1px solid color-mix(in srgb, var(--border) 40%, transparent);
  border-radius: 14px; overflow: hidden;
  opacity: 0; pointer-events: none;
  transition: opacity 0.25s cubic-bezier(0.16,1,0.3,1), transform 0.25s cubic-bezier(0.16,1,0.3,1);
  box-shadow: 0 16px 64px color-mix(in srgb, var(--surface) 70%, black), 0 0 0 1px color-mix(in srgb, var(--border) 20%, transparent);
}
.search-dialog.active { opacity: 1; pointer-events: auto; transform: translateX(-50%) translateY(0) scale(1); }
.search-dialog-input-area { display: flex; align-items: center; gap: 12px; padding: 14px 18px; border-bottom: 1px solid color-mix(in srgb, var(--border) 25%, transparent); }
.search-dialog-input-area svg { width: 16px; height: 16px; color: var(--text-tertiary); flex-shrink: 0; }
.search-dialog-input {
  flex: 1; background: transparent; font-size: 14px; font-weight: 400; color: var(--text-primary);
  outline: none;
}
.search-dialog-input::placeholder { color: color-mix(in srgb, var(--text-tertiary) 45%, transparent); }
.search-dialog-results { max-height: 360px; overflow-y: auto; padding: 6px 0; }
.search-dialog-footer {
  display: flex; align-items: center; justify-content: space-between;
  padding: 8px 18px; border-top: 1px solid color-mix(in srgb, var(--border) 15%, transparent);
  font-size: 10px; color: color-mix(in srgb, var(--text-tertiary) 35%, transparent);
}
.search-dialog-footer .hints { display: flex; gap: 12px; align-items: center; }
.search-dialog-footer .hints span { display: flex; align-items: center; gap: 4px; }
.search-dialog-footer kbd {
  display: inline-flex; align-items: center; justify-content: center;
  min-width: 16px; height: 16px; padding: 0 3px;
  font-size: 9px; font-family: 'SF Mono', ui-monospace, monospace;
  background: color-mix(in srgb, var(--surface-hover) 60%, transparent); border-radius: 3px;
}

/* ========== MAIN CONTENT ========== */
.main { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 0 32px; }
.content-wrapper { width: 100%; max-width: 680px; margin: 0 auto; display: flex; flex-direction: column; align-items: center; margin-top: 64px; gap: 48px; }

/* ========== TIME DISPLAY ========== */
.time-display { display: flex; flex-direction: column; align-items: center; gap: 6px; opacity: 0; animation: fadeSlideUp 0.8s cubic-bezier(0.16,1,0.3,1) 0.1s forwards; }
.time-display .time { font-size: 64px; font-weight: 200; letter-spacing: -0.03em; color: var(--text-primary); font-variant-numeric: tabular-nums; line-height: 1; }
.time-display .greeting { font-size: 15px; font-weight: 400; color: var(--text-secondary); letter-spacing: 0.01em; }
.time-display .date { font-size: 12px; font-weight: 400; color: var(--text-tertiary); letter-spacing: 0.02em; margin-top: 2px; }

/* ========== QUICK LAUNCH ========== */
.quick-launch { width: 100%; opacity: 0; animation: fadeSlideUp 0.8s cubic-bezier(0.16,1,0.3,1) 0.2s forwards; }
.quick-launch-row { display: flex; align-items: flex-start; justify-content: center; gap: 28px; overflow-x: auto; padding: 8px 0; }
.quick-launch-row::-webkit-scrollbar { display: none; }
.ql-item {
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  flex-shrink: 0; cursor: pointer; position: relative; user-select: none;
  transition: transform 0.3s cubic-bezier(0.16,1,0.3,1);
}
.ql-item:hover { transform: translateY(-2px); }
.ql-item img {
  width: 36px; height: 36px; border-radius: 10px;
  transition: transform 0.3s cubic-bezier(0.16,1,0.3,1), box-shadow 0.3s ease;
}
.ql-item:hover img { transform: scale(1.08); box-shadow: 0 4px 12px color-mix(in srgb, var(--surface) 60%, black); }
.ql-item .ql-title { font-size: 11px; font-weight: 400; color: var(--text-tertiary); white-space: nowrap; max-width: 72px; overflow: hidden; text-overflow: ellipsis; transition: color 0.25s ease; }
.ql-item:hover .ql-title { color: var(--text-secondary); }
.ql-add {
  display: flex; flex-direction: column; align-items: center; gap: 8px;
  flex-shrink: 0; color: var(--text-tertiary); transition: all 0.3s cubic-bezier(0.16,1,0.3,1);
}
.ql-add:hover { color: var(--text-secondary); transform: translateY(-2px); }
.ql-add-icon {
  width: 36px; height: 36px; border-radius: 10px; display: flex; align-items: center; justify-content: center;
  border: 1px dashed color-mix(in srgb, var(--text-tertiary) 25%, transparent);
  transition: border-color 0.3s ease, background 0.3s ease;
}
.ql-add:hover .ql-add-icon { border-color: color-mix(in srgb, var(--text-secondary) 35%, transparent); background: color-mix(in srgb, var(--surface-hover) 50%, transparent); }
.ql-add-icon svg { width: 14px; height: 14px; stroke-width: 1.5; }
.ql-add span { font-size: 11px; font-weight: 400; }

/* Inline add form */
.ql-form {
  display: flex; align-items: center; justify-content: center; gap: 12px;
  margin-top: 16px; overflow: hidden;
  max-height: 0; opacity: 0; transition: max-height 0.25s cubic-bezier(0.16,1,0.3,1), opacity 0.25s ease, margin 0.25s ease;
}
.ql-form.active { max-height: 60px; opacity: 1; }
.ql-form input {
  background: transparent; font-size: 13px; font-weight: 400; color: var(--text-primary);
  padding: 6px 8px; outline: none;
  border: none; border-bottom: 1px solid color-mix(in srgb, var(--text-tertiary) 25%, transparent);
  transition: border-color 0.3s ease;
}
.ql-form input:focus { border-bottom-color: var(--text-secondary); }
.ql-form .btn-text { font-size: 12px; font-weight: 500; color: var(--text-tertiary); transition: color 0.2s ease; }
.ql-form .btn-text:hover { color: var(--text-primary); }
.ql-form .btn-text:disabled { opacity: 0.3; cursor: not-allowed; }

/* ========== CATEGORIES ========== */
.categories { width: 100%; opacity: 0; animation: fadeSlideUp 0.8s cubic-bezier(0.16,1,0.3,1) 0.3s forwards; }
.category { min-width: 0; }
.category-header { display: flex; align-items: center; gap: 8px; padding: 10px 0 6px; }
.category-header .collapse-btn { color: var(--text-tertiary); transition: color 0.2s ease; flex-shrink: 0; }
.category-header .collapse-btn:hover { color: var(--text-secondary); }
.category-header .collapse-btn svg { width: 14px; height: 14px; stroke-width: 1.5; }
.category-header .cat-name {
  font-size: 11px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--text-tertiary); transition: color 0.2s ease; cursor: pointer;
}
.category-header .cat-name:hover { color: var(--text-secondary); }
.category-header .cat-actions { display: flex; gap: 2px; opacity: 0; transition: opacity 0.25s ease; }
.category-header:hover .cat-actions { opacity: 1; }
.category-header .cat-actions button { padding: 4px; color: var(--text-tertiary); transition: color 0.2s ease; border-radius: 4px; }
.category-header .cat-actions button:hover { color: var(--text-primary); background: var(--surface-hover); }
.category-header .cat-actions button svg { width: 12px; height: 12px; }

.cat-links { margin-left: 22px; overflow: hidden; max-height: 0; opacity: 0; transition: max-height 0.3s cubic-bezier(0.16,1,0.3,1), opacity 0.3s ease; }
.cat-links.open { max-height: 600px; opacity: 1; }

.link-row {
  display: flex; align-items: center; gap: 10px; padding: 6px 6px; border-radius: 6px;
  position: relative; transition: all 0.2s cubic-bezier(0.16,1,0.3,1);
}
.link-row:hover { background: var(--card-row-hover, var(--surface-hover)); padding-left: 10px; }
.link-row .grip { opacity: 0; transition: opacity 0.2s ease; flex-shrink: 0; pointer-events: none; }
.link-row:hover .grip { opacity: 0.25; }
.link-row .grip svg { width: 10px; height: 10px; color: var(--text-tertiary); }
.link-row img { width: 16px; height: 16px; border-radius: 4px; flex-shrink: 0; }
.link-row .link-title {
  font-size: 13px; font-weight: 400; color: var(--text-secondary); flex: 1; min-width: 0;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  transition: color 0.2s ease;
}
.link-row:hover .link-title { color: var(--text-primary); }
.link-row .ext-icon { opacity: 0; transition: opacity 0.2s ease; flex-shrink: 0; pointer-events: none; }
.link-row:hover .ext-icon { opacity: 0.3; }
.link-row .ext-icon svg { width: 11px; height: 11px; color: var(--text-tertiary); }
.link-row .link-actions {
  position: absolute; right: 4px; top: 50%; transform: translateY(-50%);
  display: flex; gap: 1px; opacity: 0; transition: opacity 0.2s ease;
}
.link-row:hover .link-actions { opacity: 1; }
.link-row .link-actions button { padding: 4px; color: var(--text-tertiary); transition: color 0.15s ease; border-radius: 4px; }
.link-row .link-actions button:hover { color: var(--text-primary); background: var(--surface-hover); }
.link-row .link-actions button svg { width: 12px; height: 12px; }

.add-category {
  margin-left: 22px; padding: 10px 0 4px; display: flex; align-items: center; gap: 6px;
  color: var(--text-tertiary); transition: color 0.2s ease;
}
.add-category:hover { color: var(--text-secondary); }
.add-category svg { width: 12px; height: 12px; stroke-width: 1.5; }
.add-category span { font-size: 11px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; }

/* ========== CARD BOXES (Free-positioned categories) ========== */
.card-canvas {
  position: relative;
  width: 100%;
  min-height: 400px;
}
.card-box {
  position: absolute;
  min-width: 180px;
  min-height: 120px;
  background: var(--card-bg, var(--surface));
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: clip;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  transition: box-shadow 0.2s ease;
  user-select: none;
}
.card-box:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.25); }
.card-box.dragging { box-shadow: 0 8px 32px rgba(0,0,0,0.35); z-index: 100; opacity: 0.92; }
.card-box-header {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 10px 12px;
  cursor: grab;
  border-bottom: 1px solid var(--border);
  flex-shrink: 0;
}
.card-box-header:active { cursor: grabbing; }
.card-box-header .cat-name {
  flex: 1;
  font-size: 12px;
  font-weight: 500;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.card-box-header .cat-actions { display: flex; gap: 2px; opacity: 0; transition: opacity 0.2s ease; }
.card-box:hover .cat-actions { opacity: 1; }
.card-box-header .cat-actions button { padding: 3px; color: var(--text-tertiary); border: none; background: none; cursor: pointer; border-radius: 4px; transition: all 0.15s ease; display: flex; align-items: center; }
.card-box-header .cat-actions button:hover { color: var(--text-primary); background: var(--surface-hover); }
.card-box-header .cat-actions button svg { width: 12px; height: 12px; }
.card-box-body {
  flex: 1;
  overflow-y: auto;
  padding: 4px 0;
}
.card-box-body::-webkit-scrollbar { width: 3px; }
.card-box-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
.card-box .link-row { padding: 6px 12px; gap: 8px; }
.card-box .link-row .grip { display: none; }
.card-box .inline-form { padding: 4px 12px 8px; }
/* Resize handle */
.card-box-resize {
  position: absolute;
  right: 0; bottom: 0;
  width: 16px; height: 16px;
  cursor: nwse-resize;
  opacity: 0;
  transition: opacity 0.2s ease;
}
.card-box:hover .card-box-resize { opacity: 0.4; }
.card-box-resize::after {
  content: '';
  position: absolute;
  right: 4px; bottom: 4px;
  width: 8px; height: 8px;
  border-right: 2px solid var(--text-tertiary);
  border-bottom: 2px solid var(--text-tertiary);
}
/* Add category card */
.add-card-box {
  position: absolute;
  width: 180px;
  min-height: 120px;
  border: 2px dashed var(--border);
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6px;
  color: var(--text-tertiary);
  cursor: pointer;
  transition: all 0.2s ease;
}
.add-card-box:hover { border-color: var(--text-secondary); color: var(--text-secondary); background: var(--surface-hover); }
.add-card-box svg { width: 20px; height: 20px; stroke-width: 1.5; }
.add-card-box span { font-size: 11px; font-weight: 500; }

/* Inline add link form */
.inline-form {
  display: flex; align-items: center; gap: 8px; padding: 6px 6px;
  overflow: hidden; max-height: 0; opacity: 0;
  transition: max-height 0.25s cubic-bezier(0.16,1,0.3,1), opacity 0.25s ease, padding 0.25s ease;
}
.inline-form.active { max-height: 50px; opacity: 1; }
.inline-form input {
  flex: 1; min-width: 0; background: transparent; font-size: 13px; font-weight: 400; color: var(--text-primary);
  outline: none; border: none; border-bottom: 1px solid color-mix(in srgb, var(--text-tertiary) 25%, transparent);
  transition: border-color 0.3s ease;
}
.inline-form input:focus { border-bottom-color: var(--text-secondary); }
.inline-form .btn-sm { font-size: 12px; font-weight: 500; color: var(--text-tertiary); transition: color 0.2s ease; flex-shrink: 0; }
.inline-form .btn-sm:hover { color: var(--text-primary); }
.inline-form .btn-sm:disabled { opacity: 0.3; cursor: not-allowed; }

/* ========== SETTINGS DRAWER ========== */
.settings-overlay {
  position: fixed; inset: 0; z-index: 50;
  background: rgba(0,0,0,0.35); backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  opacity: 0; pointer-events: none; transition: opacity 0.3s ease;
}
.settings-overlay.active { opacity: 1; pointer-events: auto; }
.settings-drawer {
  position: fixed; right: 0; top: 0; z-index: 51; height: 100%; width: 100%; max-width: 300px;
  background: #f5f2ed;
  border-left: 1px solid var(--sidebar-border, var(--border));
  padding: 24px 20px; overflow-y: auto;
  color: var(--sidebar-text, #2c2c2c);
  transform: translateX(100%); transition: transform 0.35s cubic-bezier(0.16,1,0.3,1);
}
.settings-drawer .desc { color: var(--sidebar-text-tertiary, #888); }
.settings-drawer .sec-value { color: var(--sidebar-text-tertiary, #888); }
.settings-drawer .sec-arrow { color: var(--sidebar-text-tertiary, #888); }
.settings-drawer .label { color: var(--sidebar-text-secondary, #555); }
.settings-drawer .setting-row .label { color: var(--sidebar-text-secondary, #555); }
.settings-drawer .section-title { color: var(--sidebar-text-tertiary, #888); }
.settings-drawer .setting-label { color: var(--sidebar-text-tertiary, #888); }
.settings-drawer .data-btn { color: var(--sidebar-text-secondary, #555); }
.settings-drawer .data-btn.danger { color: #e53e3e; }
.settings-drawer .divider { background: var(--sidebar-border, #ddd); }
.settings-drawer .slider-label { color: var(--sidebar-text-tertiary, #888); }
.settings-drawer .slider-value { color: var(--sidebar-text-secondary, #555); }
.settings-drawer .pill { color: var(--sidebar-text-tertiary, #888); }
.settings-drawer .pill.active { background: var(--accent); color: #fff; }
.settings-drawer .setting-input { color: var(--sidebar-text, #2c2c2c); }
.settings-drawer .setting-input::placeholder { color: var(--sidebar-text-tertiary, #aaa); }
.settings-drawer .switch .thumb { background: var(--sidebar-text, #2c2c2c); }
